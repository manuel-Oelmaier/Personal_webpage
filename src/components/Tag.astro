---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import linuxIcon from '../assets/Tech-icons/linux.svg';
import distributedSystemsIcon from '../assets/Tech-icons/distributed-systems.svg';
import securityIcon from '../assets/Tech-icons/security.svg';
import observabilityIcon from '../assets/Tech-icons/observability.svg';
import llmIcon from '../assets/Tech-icons/llm.svg';
import mcpIcon from '../assets/Tech-icons/mcp.svg';

interface Props {
	label: string;
	brandIcon?: ImageMetadata;
}

const { label, brandIcon } = Astro.props;

const builtInIcons: Record<string, ImageMetadata> = {
	'Linux / HPC': linuxIcon,
	'Distributed Systems': distributedSystemsIcon,
	Security: securityIcon,
	Observability: observabilityIcon,
	LLM: llmIcon,
	MCP: mcpIcon,
};

const icon = brandIcon ?? builtInIcons[label];
---

<span class="tag">
	{icon && <Image src={icon} alt="" class="icon" />}
	{label}
</span>
