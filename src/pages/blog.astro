---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

function formatPubDate(date: Date): string {
    return date.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
    });
}

const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout
    title="Blog | Manuel Oelmaier"
    description="Problem-first engineering notes on infrastructure, homelab, and AI — from Manuel Oelmaier."
    ogTitle="Blog | Manuel Oelmaier"
>
    <section class="fade-in blog-archive">
        <header class="page-header">
            <h1>Blog</h1>
            <p class="section-subtitle">Problem-first write-ups on infrastructure, AI, and engineering.</p>
        </header>

        <div class="blog-body">
            <p class="blog-intro">
                Each post covers one problem — what I tried, how I solved it, and links to go further.
                Full project showcases live on the <a href="/">homepage</a>.
                Spotted an error or have a better idea? Email me from any post.
            </p>
            <h2 class="visually-hidden">Posts</h2>
            <div class="projects-grid blog-posts">
                {allPosts.map((entry) => (
                    <article class="card">
                        <time class="post-date blog-card-date" datetime={entry.data.pubDate.toISOString()}>
                            {formatPubDate(entry.data.pubDate)}
                        </time>
                        <h3 class="title">{entry.data.title}</h3>
                        <p>{entry.data.description}</p>
                        <a href={`/blog/${entry.id.replace('.md', '')}`} class="button-link blog-button card-action">
                            Read More
                        </a>
                    </article>
                ))}
            </div>

            <div class="blog-archive-footer">
                <a href="/" class="button-link blog-button button-outline">Back to Home</a>
            </div>
        </div>
    </section>
</BaseLayout>
