---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Blog | Manuel Oelmaier">
    <section class="fade-in">
        <div class="hero-text" style="min-height: 20vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <h1 id="name">Blog</h1>
            <p class="hero-tagline">Polished project write-ups — the problems they solved and why I built them this way.</p>
        </div>
        
        <div class="about-me-content">
            <h2 class="visually-hidden">Posts</h2>
            <div class="projects-grid" style="text-align: left; margin-top: 2rem;">
                {allPosts.map((entry) => (
                    <article class="card">
                        <h3 class="title">{entry.data.title}</h3>
                        <p>{entry.data.description}</p>
                        <a href={`/blog/${entry.id.replace('.md', '')}`} class="button-link blog-button" style="font-style: normal; width: fit-content; margin: 0; padding: 0.6rem 1.5rem;">
                            Read More
                        </a>
                    </article>
                ))}
            </div>
            
            <div style="margin-top: 4rem; margin-bottom: 6rem; text-align: center;">
                <a href="/" class="button-link blog-button" style="background-color: transparent; border: 1px solid var(--normal-TextColor); color: var(--normal-TextColor);">Back to Home</a>
            </div>
        </div>
    </section>
</BaseLayout>
