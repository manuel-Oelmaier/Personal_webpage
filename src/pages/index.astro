---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tag from '../components/Tag.astro';
import { getImage, Image } from 'astro:assets';

import manuImg from '../assets/manu.jpg';
import exampleQuery from '../assets/Projects/exampleQuery.png';

import pytorchIcon from '../assets/Tech-icons/pytorch.svg';
import pythonIcon from '../assets/Tech-icons/python.svg';
import typescriptIcon from '../assets/Tech-icons/typescript.svg';
import dockerIcon from '../assets/Tech-icons/docker.svg';
import ansibleIcon from '../assets/Tech-icons/ansible.svg';
import traefikIcon from '../assets/Tech-icons/traefik.svg';
import tailscaleIcon from '../assets/Tech-icons/tailscale.svg';
import githubIcon from '../assets/github-mark-white.svg';
import linkedinIcon from '../assets/linkedin.png';

const metaDescription =
    'Software Engineer · AI / LLM · Munich · TUM. End-to-end LLM systems — research, finetuning, and production deployment. Open to engineering roles and contract work.';

const site = Astro.site ?? new URL('https://manueloelmaier.de');
const personSchema = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Manuel Oelmaier',
    url: site.href,
    jobTitle: 'Software Engineer · AI / LLM',
    description: metaDescription,
    email: 'manuel@oelmaier.eu',
    sameAs: [
        'https://www.linkedin.com/in/manuel-oelmaier/',
        'https://github.com/manuel-Oelmaier',
    ],
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Munich',
        addressCountry: 'DE',
    },
    alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Technical University of Munich',
    },
    knowsAbout: ['Python', 'TypeScript', 'LLM', 'Machine Learning', 'Distributed Systems'],
};

const heroImage = await getImage({ src: manuImg, width: 480, height: 480, format: 'webp' });
---

<BaseLayout
    title="Manuel Oelmaier"
    description={metaDescription}
    ogTitle="Software Engineer · AI / LLM | Manuel Oelmaier"
    jsonLd={personSchema}
    preloadImages={[heroImage.src]}
>
    <section id="about-me" class="hero">
        <div class="hero-inner">
            <div class="hero-photo">
                <Image
                    id="manu-img"
                    src={manuImg}
                    alt="Profile picture of Manuel Oelmaier"
                    width={480}
                    height={480}
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
            <div class="hero-text">
                <h1>Software Engineer · AI / LLM</h1>
                <p class="hero-hook">
                    I build LLM systems end to end — research, finetuning, and production deployment.
                </p>
                <p class="hero-proof">
                    Ongoing bachelor thesis at TUM on efficient LLM inference
                    (<strong>Hidden State Informed Token Eviction</strong>), a shipped VS Code extension with local models,
                    and production infra — including zero-downtime engine analysis at the
                    <strong>2026 FIDE Candidates Tournament</strong>.
                </p>
                <p class="hero-meta">
                    Munich · TUM · Python · TypeScript<br />
                    BSc completing September 2026 · MSc at TUM to follow
                </p>
                <div class="hero-actions">
                    <a href="/cv_manuel_Oelmaier_EN.pdf" target="_blank" class="button-link hero-cta-primary">
                        <svg class="hero-cta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2 5 5h-5V4zM8 12h8v2H8v-2zm0 4h8v2H8v-2z"/>
                        </svg>
                        Download CV
                    </a>
                    <a href="mailto:manuel@oelmaier.eu" class="button-link hero-cta-secondary">manuel@oelmaier.eu</a>
                </div>
            </div>
        </div>
    </section>

    <section id="featured-work" class="fade-in">
        <h2>Featured Work</h2>
        <p class="section-subtitle">Flagship production work — ownership, outcomes, and reliability under pressure.</p>
        <div class="projects-grid">
            <article class="card card-featured">
                <h3 class="title">Distributed Analysis Infrastructure — Elite Chess</h3>
                <p>
                    I designed, secured, and operated the engine-analysis infrastructure for a top team at the
                    <strong>2026 FIDE Candidates Tournament</strong> — the event that decided the challenger for the
                    World Chess Championship. I owned deployment, secure remote access, an observability and control
                    dashboard, and cost-aware scaling, delivering <strong>zero unplanned downtime</strong> across months
                    of preparation and the event. The team won with a record-breaking 10/14.
                </p>
                <p class="confidential-note">
                    Full technical details are confidential. A recommendation letter from the team's Chief Trainer is available on request.
                </p>
                <a
                    href="mailto:manuel@oelmaier.eu?subject=Recommendation%20letter%20request%20%E2%80%94%20FIDE%20Candidates%20infrastructure"
                    class="project-link button-link"
                >
                    Request recommendation letter
                </a>
                <div class="tags">
                    <Tag label="Linux / HPC" />
                    <Tag label="Distributed Systems" />
                    <Tag label="Security" />
                    <Tag label="Observability" />
                </div>
            </article>
        </div>
    </section>

    <section id="projects" class="fade-in">
        <h2>Project Showcase</h2>
        <p class="section-subtitle">Research, shipped products, and infrastructure depth.</p>
        <div class="projects-grid">
            <article class="card">
                <h3 class="title">Bachelor Thesis (ongoing) — Hidden State Informed Token Eviction</h3>
                <p>
                    <strong>Ongoing</strong> research at TUM on <strong>efficient LLM inference</strong>: not every token needs exact
                    memory — designing different <strong>levels of importance</strong> for what a model keeps verbatim versus in
                    summary. Pluggable framework on Hugging Face Transformers; cross-backbone evaluation still in progress.
                </p>
                <a href="/blog/efficient-llm-inference-thesis" class="project-link project-link-sketch button-link">
                    <svg class="project-link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2 5 5h-5V4zM8 12h8v2H8v-2zm0 4h5v2H8v-2z"/>
                    </svg>
                    <span>Read the research sketch</span>
                </a>
                <div class="tags">
                    <Tag label="PyTorch" brandIcon={pytorchIcon} />
                    <Tag label="Python" brandIcon={pythonIcon} />
                    <Tag label="LLM" />
                </div>
            </article>

            <article class="card">
                <h3 class="title">LocalPythonCodingLlm</h3>
                <p>Fine-tuned and benchmarked multiple small LLMs for Python code generation, then shipped the best-performing model 
                    as a <abbr title="Visual Studio Code">VS Code</abbr> extension with fully local inference. 
                    Local execution was a deliberate architectural choice — LLMs require unencrypted input, 
                    and running on-device eliminates the privacy trade-off entirely.</p>
                <Image class="card-Showcase" src={exampleQuery} alt="VS Code extension running a local Python coding LLM with an inline code suggestion" width={600} />
                <a href="https://github.com/manuel-Oelmaier/LocalPythonCodingLlm" target="_blank"
                   class="project-link project-link-github button-link">
                    <Image src={githubIcon} alt="GitHub Logo" class="icon" />
                    <span>View on GitHub</span>
                </a>
                <div class="tags">
                    <Tag label="Python" brandIcon={pythonIcon} />
                    <Tag label="PyTorch" brandIcon={pytorchIcon} />
                    <Tag label="TypeScript" brandIcon={typescriptIcon} />
                </div>
            </article>

            <article class="card">
                <h3 class="title">Production AI Platform — Homelab</h3>
                <p>
                    Designed and operate a Tailscale-only personal cloud on self-managed hardware, replacing SaaS
                    for chat, notes, calendar, and messaging. Built as modular Docker Compose stacks behind Traefik
                    with a private CA, pull-based GitOps deployment gated on CI, and encrypted Restic backups.
                </p>
                <p>
                    The centerpiece is a <strong>LibreChat deployment with local GPU inference</strong> (Ollama) and
                    three privacy-tiered AI agents connected via <strong>Model Context Protocol</strong> — including
                    custom MCP servers for grocery APIs and health data. Security enforced as code: automated
                    network-exposure audits, TLS validation, and agent privacy-policy tests run on a schedule from a
                    dedicated monitoring node.
                </p>
                <a href="/blog/homelab-ai-platform" class="project-link project-link-sketch button-link">
                    <svg class="project-link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2 5 5h-5V4zM8 12h8v2H8v-2zm0 4h5v2H8v-2z"/>
                    </svg>
                    <span>Read the write-up</span>
                </a>
                <div class="tags">
                    <Tag label="Docker" brandIcon={dockerIcon} />
                    <Tag label="Traefik" brandIcon={traefikIcon} />
                    <Tag label="Tailscale" brandIcon={tailscaleIcon} />
                    <Tag label="Ansible" brandIcon={ansibleIcon} />
                    <Tag label="Python" brandIcon={pythonIcon} />
                    <Tag label="MCP" />
                </div>
            </article>

        </div>
    </section>

    <section id="principles" class="fade-in">
        <h2>Principles</h2>
        <div class="principles-grid">
            <div class="principle">
                <h3>Pragmatism</h3>
                <p>
                    I prefer simple systems that solve the real problem. Ship, get feedback, and only add complexity
                    when it clearly buys reliability, speed, or clarity.
                </p>
            </div>
            <div class="principle">
                <h3>Software Craftsmanship</h3>
                <p>
                    I care about code that other people can run, read, and change. Good architecture means clear
                    boundaries, boring tools where they fit, and fewer surprises in production.
                </p>
            </div>
            <div class="principle">
                <h3>Lifelong Learning</h3>
                <p>
                    I learn by building. Side projects and research questions, from homelab automation to linear
                    attention, are how I test ideas against reality. The same applies to tournament chess — including
                    coaching juniors at SC Eching.
                </p>
            </div>
        </div>
    </section>

    <section id="contact" class="fade-in">
        <h2>Contact</h2>
        <div class="contact-text">
            <p>Open to software engineering roles, contract work, and technical collaborations. Also open to working-student roles when the work is real engineering I can grow from. If something I've built is relevant to what you're working on — reach out.</p>
            <div class="contact-actions">
                <a href="https://www.linkedin.com/in/manuel-oelmaier/" target="_blank" class="social-link" aria-label="LinkedIn">
                    <Image src={linkedinIcon} alt="" class="social-icon" />
                </a>
                <a href="mailto:manuel@oelmaier.eu" class="button-link contact-button">Get in touch</a>
                <a href="https://github.com/manuel-Oelmaier" target="_blank" class="social-link" aria-label="GitHub">
                    <Image src={githubIcon} alt="" class="social-icon" />
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
