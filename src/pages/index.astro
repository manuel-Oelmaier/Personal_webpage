---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

// Import assets
import manuImg from '../assets/manu.jpg';
import exampleQuery from '../assets/Projects/exampleQuery.png';

// Icon imports
import pytorchIcon from '../assets/Tech-icons/pytorch.svg';
import pythonIcon from '../assets/Tech-icons/python.svg';
import typescriptIcon from '../assets/Tech-icons/typescript.svg';
import dockerIcon from '../assets/Tech-icons/docker.svg';
import ansibleIcon from '../assets/Tech-icons/ansible.svg';
import traefikIcon from '../assets/Tech-icons/traefik.svg';
import tailscaleIcon from '../assets/Tech-icons/tailscale.svg';
import githubIcon from '../assets/github-mark-white.svg';
import linkedinIcon from '../assets/linkedin.png';
---

<BaseLayout title="Manuel Oelmaier">
    <section class="hero">
        <div class="hero-text">
            <h1 id="name">Manuel Oelmaier</h1>
            <p id="name-description">Software Engineer · AI / LLM Engineer</p>
            <p class="hero-tagline">I write clean code and architect solid systems, with a specialization in applying that discipline to AI integration.</p>
        </div>
    </section>

    <section id="about-me" class="fade-in">
        <div class="about-container">
            <div class="about-image">
                <Image id="manu-img" src={manuImg} alt="Profile picture of Manuel" width={320} height={320} />
            </div>
            <div class="about-content">
                <h2>About me</h2>
                <p>
                    I study CS at <strong>TU Munich (TUM)</strong>, one of Europe's top engineering programs, 
                    and have already shipped production systems in high-stakes environments. I specialize in AI end-to-end: 
                    from pretraining and model evaluation to production integration with proper tooling.
                </p>
                <ul class="about-list">
                    <li><strong>Stack:</strong> Python and TypeScript primarily, Java when the situation calls for it.</li>
                    <li><strong>Interests:</strong> Digital sovereignty, intelligent automation, and what intelligence actually is at its core.</li>
                    <li><strong>Off-duty:</strong> Competitive chess player and gym enthusiast.</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="fade-in">
        <h2>Principles</h2>
        <div class="principles-grid">
            <div class="principle">
                <h3>Pragmatism</h3>
                <p>
                    I prefer simple systems that solve the real problem. Ship, get feedback, and only add complexity
                    when it clearly buys reliability, speed, or clarity.
                </p>
            </div>
            <div class="principle">
                <h3>Software Craftsmanship</h3>
                <p>
                    I care about code that other people can run, read, and change. Good architecture means clear
                    boundaries, boring tools where they fit, and fewer surprises in production.
                </p>
            </div>
            <div class="principle">
                <h3>Lifelong Learning</h3>
                <p>
                    I learn by building. Side projects and research questions, from homelab automation to linear
                    attention, are how I test ideas against reality.
                </p>
            </div>
        </div>
    </section>

    <section id="resume" class="fade-in">
        <h2>CV</h2>
        <p>A concise overview of my skills, experience, and projects.</p>
        <a href="/cv_manuel_Oelmaier_EN.pdf" target="_blank" class="resume-button button-link">Download CV</a>
    </section>

    <section id="featured-work" class="fade-in">
        <h2>Featured Work</h2>
        <div class="projects-grid">
            <article class="card">
                <h3 class="title">Distributed Analysis Infrastructure — Elite Chess</h3>
                <p>
                    I designed, secured, and operated the engine-analysis infrastructure for a top team at the
                    <strong>2026 FIDE Candidates Tournament</strong> — the event that decides the challenger for the
                    World Chess Championship. I owned deployment, secure remote access, an observability and control
                    dashboard, and cost-aware scaling, delivering <strong>zero unplanned downtime</strong> across months
                    of preparation and the event. The team won with a record-breaking 10/14.
                </p>
                <p class="confidential-note">
                    Full technical details are confidential. Architecture and outcomes available under NDA / on request;
                    recommendation letter from the team's Chief Trainer available.
                </p>
                <div class="tags">
                    <span class="tag">Linux / HPC</span>
                    <span class="tag">Distributed Systems</span>
                    <span class="tag">Security</span>
                    <span class="tag">Observability</span>
                </div>
            </article>
        </div>
    </section>

    <section id="projects" class="fade-in">
        <h2>Project Showcase</h2>
        <div class="projects-grid">
            <article class="card">
                <h3 class="title">Self-Hosted Homelab &amp; AI Agent Platform</h3>
                <p>
                    Designed and operate a Tailscale-only personal cloud on self-managed hardware, replacing SaaS
                    for chat, notes, calendar, and messaging. Built as modular Docker Compose stacks behind Traefik
                    with a private CA, pull-based GitOps deployment gated on CI, and encrypted Restic backups.
                </p>
                <p>
                    The centerpiece is a <strong>LibreChat deployment with local GPU inference</strong> (Ollama) and
                    five privacy-tiered AI agents connected via <strong>Model Context Protocol</strong> — including
                    custom MCP servers for grocery APIs and health data. Security enforced as code: automated
                    network-exposure audits, TLS validation, and agent privacy-policy tests run on a schedule from a
                    dedicated monitoring node.
                </p>
                <a href="/blog/homelab-ai-platform" class="project-link button-link" style="margin-bottom: 0.5rem;">
                    <span>Read the write-up</span>
                </a>
                <div class="tags">
                    <span class="tag"><Image src={dockerIcon} alt="Docker logo" class="icon" /> Docker</span>
                    <span class="tag"><Image src={traefikIcon} alt="Traefik logo" class="icon" /> Traefik</span>
                    <span class="tag"><Image src={tailscaleIcon} alt="Tailscale logo" class="icon" /> Tailscale</span>
                    <span class="tag"><Image src={ansibleIcon} alt="Ansible logo" class="icon" /> Ansible</span>
                    <span class="tag"><Image src={pythonIcon} alt="Python logo" class="icon" /> Python</span>
                    <span class="tag">LLM / MCP</span>
                </div>
            </article>

            <article class="card">
                <h3 class="title">LocalPythonCodingLlm</h3>
                <p>Fine-tuned and benchmarked multiple small LLMs for Python code generation, then shipped the best-performing model 
                    as a <abbr title="Visual Studio Code">VS Code</abbr> extension with fully local inference. 
                    Local execution was a deliberate architectural choice — LLMs require unencrypted input, 
                    and running on-device eliminates the privacy trade-off entirely.</p>
                <Image class="card-Showcase" src={exampleQuery} alt="Screenshot of a sample query" width={600} />
                <a href="https://github.com/manuel-Oelmaier/LocalPythonCodingLlm" target="_blank"
                   class="project-link button-link">
                    <Image src={githubIcon} alt="GitHub Logo" class="icon" />
                    <span>View on GitHub</span>
                </a>
                <div class="tags">
                    <span class="tag"><Image src={pythonIcon} alt="python logo" class="icon" /> Python</span>
                    <span class="tag"><Image src={pytorchIcon} alt="PyTorch logo" class="icon" /> PyTorch</span>
                    <span class="tag"><Image src={typescriptIcon} alt="TypeScript logo" class="icon" /> TypeScript</span>
                </div>
            </article>

        </div>
    </section>

    <section id="code" class="fade-in">
        <h2>Code</h2>
        <p class="section-subtitle">Recent commit activity across public repositories — last 30 days.</p>
        <div class="gh-activity" id="gh-activity">
            <p class="gh-loading">Loading…</p>
        </div>
        <script>
            async function renderActivity() {
                const container = document.getElementById('gh-activity');
                if (!container) return;
                try {
                    const res = await fetch('/github-activity.json');
                    const data = await res.json();
                    if (!data.repos || data.repos.length === 0) {
                        container.innerHTML = '<p class="gh-empty">No recent public activity.</p>';
                        return;
                    }
                    const max = data.repos[0].commits;
                    const rows = data.repos.map((r: {name: string; commits: number; lastPush: string}) => `
                        <div class="gh-row">
                            <span class="gh-repo">${r.name}</span>
                            <div class="gh-bar-wrap">
                                <div class="gh-bar" style="width:${Math.round((r.commits / max) * 100)}%"></div>
                            </div>
                            <span class="gh-count">${r.commits}</span>
                        </div>
                    `).join('');
                    const updated = data.updated
                        ? new Date(data.updated).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
                        : null;
                    container.innerHTML = `
                        <div class="gh-rows">${rows}</div>
                        ${updated ? `<p class="gh-updated">updated ${updated}</p>` : ''}
                    `;
                } catch {
                    container.innerHTML = '<p class="gh-empty">Could not load activity.</p>';
                }
            }
            renderActivity();
        </script>
    </section>

    <section id="contact" class="fade-in">
        <h2>Contact</h2>
        <div class="contact-text">
            <p>Open to internships, working student roles, and engineering collaborations. If something I’ve built is relevant to what you’re working on — reach out.</p>
            <a href="mailto:manuel@oelmaier.eu" class="button-link contact-button" style="font-style:normal;">Get in touch</a>
            <div class="social-links">
                <a href="https://www.linkedin.com/in/manuel-oelmaier/" target="_blank" aria-label="LinkedIn">
                    <Image src={linkedinIcon} alt="" class="social-icon" />
                </a>
                <a href="https://github.com/manuel-Oelmaier" target="_blank" aria-label="GitHub">
                    <Image src={githubIcon} alt="" class="social-icon" />
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
