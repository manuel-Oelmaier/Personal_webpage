---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type BlogEntry = CollectionEntry<'blog'>;

interface Props {
    entry: BlogEntry;
}

type StaticPath = {
    params: { slug: string };
    props: Props;
};

function formatPubDate(date: Date): string {
    return date.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
    });
}

export async function getStaticPaths(): Promise<StaticPath[]> {
    const blogEntries = await getCollection('blog');
    return blogEntries.map((entry) => ({
        params: { slug: entry.id.replace('.md', '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, pubDate, tags, problem } = entry.data;
const isMeta = tags.includes('meta');
const formattedDate = formatPubDate(pubDate);
const tagLine = tags.length > 0 ? ` • ${tags.join(', ')}` : '';
const readingTime = Math.ceil(entry.body.split(/\s+/).length / 200);

const slug = entry.id.replace('.md', '');
const site = Astro.site ?? new URL('https://manueloelmaier.de');
const postUrl = new URL(`/blog/${slug}/`, site);
const ogImage = `/og/blog/${slug}.jpg`;
const publishedIso = pubDate.toISOString();

const articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    datePublished: publishedIso,
    author: {
        '@type': 'Person',
        name: 'Manuel Oelmaier',
        url: site.href,
    },
    image: new URL(ogImage, site).href,
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': postUrl.href,
    },
    publisher: {
        '@type': 'Person',
        name: 'Manuel Oelmaier',
    },
};
---

<BaseLayout
    title={`${title} | Manuel Oelmaier`}
    description={description}
    ogTitle={`${title} | Manuel Oelmaier`}
    ogImage={ogImage}
    ogType="article"
    articlePublishedTime={publishedIso}
    jsonLd={articleSchema}
>
    <article class="fade-in blog-post">
        <h1 class="post-title">{title}</h1>
        <p class="post-meta">Published on {formattedDate}{tagLine} · {readingTime} min read</p>
        <hr class="post-divider" />

        {problem && (
            <aside class="post-problem">
                <span class="post-problem-label">The problem</span>
                <p>{problem}</p>
            </aside>
        )}

        <div class="post-content">
            <Content />
        </div>

        <div class="post-footer">
            {!isMeta && (
                <div class="post-contact">
                    <p>Spotted an error, know a better approach, or have a question this post didn't cover? I read and reply to every email.</p>
                    <a
                        href={`mailto:manuel@oelmaier.eu?subject=${encodeURIComponent(`Re: ${title}`)}`}
                        class="button-link contact-button"
                    >
                        Get in touch
                    </a>
                </div>
            )}
            <a href="/blog" class="button-link blog-button">Back to Blog Archive</a>
        </div>
    </article>
</BaseLayout>
