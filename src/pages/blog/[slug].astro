---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type BlogEntry = CollectionEntry<'blog'>;

interface Props {
    entry: BlogEntry;
}

type StaticPath = {
    params: { slug: string };
    props: Props;
};

function formatPubDate(date: Date): string {
    return date.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
    });
}

export async function getStaticPaths(): Promise<StaticPath[]> {
    const blogEntries = await getCollection('blog');
    return blogEntries.map((entry) => ({
        params: { slug: entry.id.replace('.md', '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, pubDate, tags, motivation } = entry.data;
const formattedDate = formatPubDate(pubDate);
const tagLine = tags.length > 0 ? ` • ${tags.join(', ')}` : '';
const readingTime = Math.ceil(entry.body.split(/\s+/).length / 200);
---

<BaseLayout title={`${title} | Manuel Oelmaier`}>
    <article class="fade-in about-me-content" style="text-align: left; padding: 4rem 2rem; flex-grow: 1; max-width: 900px;">
        <h1 style="font-size: 3.5rem; color: hsl(216, 40%, 90%); margin-bottom: 0.5rem; text-align: center;">{title}</h1>
        <p class="post-meta">Published on {formattedDate}{tagLine} · {readingTime} min read</p>
        <hr style="border: 0; border-top: 1px solid rgba(255,255,255, 0.1); margin: 2rem 0 3rem 0;" />

        {motivation && (
            <aside class="post-motivation">
                <span class="post-motivation-label">Why this?</span>
                <p>{motivation}</p>
            </aside>
        )}
        
        <div class="post-content">
            <Content />
        </div>
        
        <div style="margin-top: 6rem; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 3rem;">
            <a href="/blog" class="button-link blog-button">Back to Blog Archive</a>
        </div>
    </article>
</BaseLayout>

<style is:global>
    .post-content h2 {
        font-size: 2.2rem;
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        text-align: left;
    }
    .post-content p {
        font-size: 1.2rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        text-align: left;
    }
    .post-content ul {
        margin-bottom: 2rem;
        padding-left: 2rem;
    }
    .post-content li {
        font-size: 1.2rem;
        margin-bottom: 0.7rem;
    }
    .inbox-policy {
        background: rgba(255, 255, 255, 0.03);
        border-left: 4px solid var(--normal-TextColor);
        padding: 1.8rem;
        margin: 3rem 0;
        font-style: italic;
        border-radius: 0 1rem 1rem 0;
    }
    .post-meta {
        text-align: center;
        color: hsl(210, 15%, 72%);
        font-size: 1rem;
        margin-bottom: 2rem;
    }
    .post-motivation {
        border-left: 3px solid var(--normal-TextColor);
        padding: 1.2rem 1.6rem;
        margin: 0 0 3rem 0;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 0 0.8rem 0.8rem 0;
    }
    .post-motivation-label {
        display: block;
        font-family: var(--mono-font);
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: hsl(185, 49%, 56%);
        margin-bottom: 0.6rem;
    }
    .post-motivation p {
        font-style: italic;
        color: hsl(185, 49%, 56%);
        margin-bottom: 0;
        font-size: 1.1rem;
        line-height: 1.7;
    }
</style>
