---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type BlogEntry = CollectionEntry<'blog'>;

interface Props {
    entry: BlogEntry;
}

type StaticPath = {
    params: { slug: string };
    props: Props;
};

function formatPubDate(date: Date): string {
    return date.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
    });
}

export async function getStaticPaths(): Promise<StaticPath[]> {
    const blogEntries = await getCollection('blog');
    return blogEntries.map((entry) => ({
        params: { slug: entry.id.replace('.md', '') },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, pubDate, tags, problem } = entry.data;
const isMeta = tags.includes('meta');
const formattedDate = formatPubDate(pubDate);
const tagLine = tags.length > 0 ? ` • ${tags.join(', ')}` : '';
const readingTime = Math.ceil(entry.body.split(/\s+/).length / 200);
---

<BaseLayout
    title={`${title} | Manuel Oelmaier`}
    description={description}
    ogTitle={`${title} | Manuel Oelmaier`}
    ogType="article"
>
    <article class="fade-in about-me-content" style="text-align: left; padding: 4rem 2rem; flex-grow: 1; max-width: 900px;">
        <h1 style="font-size: 3.5rem; color: hsl(216, 40%, 90%); margin-bottom: 0.5rem; text-align: center;">{title}</h1>
        <p class="post-meta">Published on {formattedDate}{tagLine} · {readingTime} min read</p>
        <hr style="border: 0; border-top: 1px solid rgba(255,255,255, 0.1); margin: 2rem 0 3rem 0;" />

        {problem && (
            <aside class="post-problem">
                <span class="post-problem-label">The problem</span>
                <p>{problem}</p>
            </aside>
        )}
        
        <div class="post-content">
            <Content />
        </div>
        
        <div class="post-footer">
            {!isMeta && (
                <div class="post-contact">
                    <p>Spotted an error, know a better approach, or have a question this post didn't cover? I read and reply to every email.</p>
                    <a
                        href={`mailto:manuel@oelmaier.eu?subject=${encodeURIComponent(`Re: ${title}`)}`}
                        class="button-link contact-button"
                        style="font-style: normal;"
                    >
                        Get in touch
                    </a>
                </div>
            )}
            <a href="/blog" class="button-link blog-button">Back to Blog Archive</a>
        </div>
    </article>
</BaseLayout>

<style is:global>
    .post-content h2 {
        font-size: 2.2rem;
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        text-align: left;
    }
    .post-content p {
        font-size: 1.2rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        text-align: left;
    }
    .post-content ul {
        margin-bottom: 2rem;
        padding-left: 2rem;
    }
    .post-content li {
        font-size: 1.2rem;
        margin-bottom: 0.7rem;
    }
    .post-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 1rem;
        line-height: 1.5;
    }
    .post-content th,
    .post-content td {
        border: 1px solid rgba(255, 255, 255, 0.12);
        padding: 0.75rem 1rem;
        text-align: left;
        vertical-align: top;
    }
    .post-content th {
        color: hsl(185, 65%, 72%);
        font-family: var(--mono-font);
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }
    .post-footer {
        margin-top: 6rem;
        text-align: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
    }
    .post-contact {
        max-width: 560px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }
    .post-contact p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: hsl(185, 49%, 56%);
        text-align: center;
        margin-bottom: 0;
    }
    .post-meta {
        text-align: center;
        color: hsl(210, 15%, 82%);
        font-size: 1rem;
        margin-bottom: 2rem;
    }
    .post-problem {
        border-left: 3px solid var(--normal-TextColor);
        padding: 1.2rem 1.6rem;
        margin: 0 0 3rem 0;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 0 0.8rem 0.8rem 0;
    }
    .post-problem-label {
        display: block;
        font-family: var(--mono-font);
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: hsl(185, 49%, 70%);
        margin-bottom: 0.6rem;
    }
    .post-problem p {
        font-style: italic;
        color: hsl(185, 49%, 70%);
        margin-bottom: 0;
        font-size: 1.1rem;
        line-height: 1.7;
    }
    .post-content a.cite {
        color: hsl(185, 65%, 72%);
        font-weight: 600;
        text-decoration: none;
        padding: 0 0.1em;
        border-bottom: 1px solid hsl(185, 49%, 45%);
        transition: color 0.2s ease, border-color 0.2s ease;
    }
    .post-content a.cite:hover {
        color: hsl(185, 80%, 85%);
        border-bottom-color: hsl(185, 65%, 72%);
    }
    .post-content .references-list {
        list-style: none;
        padding: 1.5rem 1.75rem;
        margin: 2rem 0 0;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.8rem;
        background: rgba(255, 255, 255, 0.03);
        counter-reset: reference;
    }
    .post-content .references-list li {
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 1.1rem;
        padding-left: 0.25rem;
    }
    .post-content .references-list li:last-child {
        margin-bottom: 0;
    }
    .post-content .references-list li::before {
        content: '[' counter(reference) ']';
        counter-increment: reference;
        display: inline-block;
        min-width: 2rem;
        color: hsl(185, 65%, 72%);
        font-weight: 600;
        font-family: var(--mono-font);
    }
    .post-content a.reference-link {
        color: hsl(185, 75%, 80%);
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 0.18em;
        transition: color 0.2s ease;
    }
    .post-content a.reference-link:hover {
        color: hsl(185, 90%, 92%);
    }
    .post-content .reference-meta {
        color: hsl(210, 15%, 78%);
    }
</style>
